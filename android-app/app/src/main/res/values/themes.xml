<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SupaPhone.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_base_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.SupaPhone</item>
    </style>

    <style name="Theme.SupaPhone" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@color/bg_base_dark</item>
        <item name="android:navigationBarColor">@color/bg_base_dark</item>
        <item name="android:windowBackground">@color/bg_base_dark</item>
    </style>
</resources>
