SUPABASE_URL=
SUPABASE_ANON_KEY=
# Optional hard-pin for edge auth checks (recommended to match SUPABASE_ANON_KEY value)
APP_PUBLIC_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# Firebase (required for real phone notifications)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON_PATH=./firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
# Optional (recommended for hosted Supabase Edge): raw JSON string.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Runtime behavior
LOG_RETENTION_HOURS=24
